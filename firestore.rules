rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if requester is an admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // EVENTS — public read (only published), admin write
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // TICKETS — anyone can create (booking), admin can update/delete, read open (for my-tickets page)
    match /tickets/{ticketId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ADMINS — authenticated users can read (to verify own role), only admins can write
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // WAITING LIST — anyone can create, admin manages
    match /waiting_list/{entryId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    // ACTIVITY LOG — admin only
    match /activity_log/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
